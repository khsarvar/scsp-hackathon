# Backend
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# Pydantic AI provider:model strings. Switch providers by changing the prefix.
# Anthropic: anthropic:claude-sonnet-4-6, anthropic:claude-haiku-4-5
# OpenAI:    openai-responses:gpt-5.5
AGENT_MODEL=anthropic:claude-sonnet-4-6
SCOUT_MODEL=anthropic:claude-haiku-4-5
SCOUT_REASONING_EFFORT=low

UPLOAD_DIR=/tmp/healthlab_sessions
MAX_FILE_SIZE_MB=50

# Frontend (optional, defaults to localhost:8000)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
